# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# WhatsApp — Meta Cloud API (FREE, 1000 conversations/month)
# Get these from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=sarkarinaukri-verify   # set same string in Meta webhook config

# Groq API (free at console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Telegram (for testing — get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# App
APP_ENV=development
APP_PORT=8000
BASE_URL=https://your-domain.com
